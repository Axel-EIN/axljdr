{% set path = 'admin_' ~ entity ~ '_' ~ action %}

{% if redirect is defined and redirect is not empty %}
    {% set frag_redir = 'redirect=' ~ redirect %}
{% endif %}

{% if fragment is defined and fragment is not empty %}
    {% set fragment = '#' ~ fragment %}
{% endif %}

{% if action == 'create' %}
    {% set href = path(path) %}
    {% set fa_icon, label = 'fa-plus-square', 'Ajouter' %}
{% elseif action == 'edit' %}
    {% set href = path(path, {id:un_element.id}) %}
    {% set fa_icon, label = 'fa-edit', 'Modifier' %}
{% elseif action == 'delete' %}
    {% set fa_icon, label = 'fa-trash-alt', 'Supprimer' %}
{% endif %}

{% if action == 'delete' %}
    {% set form_action = path(path, {id:un_element.id}) ~ '?' ~ frag_redir|default('') ~ fragment|default('') %}
    <form method="POST" action="{{ form_action }}" style="display:inline" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet élément ?')">
        <input type="hidden" name="_csrf_token" value="{{ csrf_token('delete' ~ un_element.id) }}">
        <button type="submit" class="{{position|default('')}} {{color}} {{size}}" style="border:none;background:none;cursor:pointer;padding:0;">
            <i class="fas {{fa_icon}}" alt="Icône {{label}}" title="{{label}}"></i>
        </button>
    </form>
{% else %}
    {% set href = href ~ '?' ~ frag_redir|default('') ~ fragment|default('') %}
    <a href="{{href}}" class="{{position|default('')}} {{color}} {{size}}">
        <i class="fas {{fa_icon}}" alt="Icône {{label}}" title="{{label}}"></i>
    </a>
{% endif %}