# Désactiver le listing des répertoires
Options -Indexes

# Activer le moteur de réécriture
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Rediriger HTTP vers HTTPS
    RewriteCond %{HTTPS} off
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Bloquer l'accès aux fichiers sensibles
    RewriteRule ^\.env - [F,L]
    RewriteRule ^composer\.(json|lock)$ - [F,L]
    RewriteRule ^symfony\.lock$ - [F,L]
    RewriteRule ^phpunit\.xml - [F,L]
    RewriteRule ^config/ - [F,L]
    RewriteRule ^migrations/ - [F,L]
    RewriteRule ^src/ - [F,L]
    RewriteRule ^templates/ - [F,L]
    RewriteRule ^var/ - [F,L]
    RewriteRule ^vendor/ - [F,L]
    RewriteRule ^bin/ - [F,L]

    # Front controller Symfony : redirige tout vers index.php
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^(.*)$ index.php [QSA,L]
</IfModule>

# Interdire l'exécution de PHP dans les dossiers d'upload
<IfModule mod_rewrite.c>
    RewriteRule ^assets/.*\.php$ - [F,L]
</IfModule>

# Headers de sécurité
<IfModule mod_headers.c>
    # Empêcher le clickjacking (iframe)
    Header always set X-Frame-Options "SAMEORIGIN"

    # Empêcher le MIME sniffing
    Header always set X-Content-Type-Options "nosniff"

    # Protection XSS navigateur
    Header always set X-XSS-Protection "1; mode=block"

    # Contrôler les informations envoyées dans le Referer
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # Forcer HTTPS pendant 1 an
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"

    # Politique de permissions (désactiver caméra, micro, géoloc, etc.)
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
</IfModule>

# Désactiver la signature du serveur
ServerSignature Off
