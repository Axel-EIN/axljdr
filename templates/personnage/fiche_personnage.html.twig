{% extends 'base.html.twig' %}

{% block title %}Fiche personnage {{ parent() }}{% endblock %}

{% block body %}

    <main class="container-fluid">
        <section class="container">

            <nav class="pt-3">
                <span class="text-muted">
                    <a href="{{ path('aventure') }}">
                        <i class="fas fa-home"></i></a>
                        > <a href="{{ path('personnages') }}"><strong>Personnages</strong></a>
                        > <a href="{{ path('personnage_profil', {id: fiche.personnage.id}) }}"><strong>{{ fiche.personnage.nom }} {{ fiche.personnage.prenom }}</strong></a>
                        > <strong>Fiche Personnage</strong>
                </span>
            </nav>

            <div class="d-flex align-items-center pt-3 mb-3">
                <h1 class="mb-0">Fiche Personnage de {{ fiche.personnage.nom }} <strong>{{ fiche.personnage.prenom }}</strong></h1>
                {% if is_granted('ROLE_MJ') %}
                    <a href="{{ path('admin_fiche_edit', {id: fiche.id}) }}" class="btn btn-warning btn-sm ml-3">
                        <i class="fas fa-edit"></i> Éditer la fiche
                    </a>
                {% endif %}
            </div>

            {% set bonusNomFamille = (fiche.personnage.famille is not empty) ? fiche.personnage.famille.bonusStatNom : null %}
            {% set bonusNomEcole   = (fiche.personnage.ecole is not empty) ? fiche.personnage.ecole.bonusStatNom : null %}
            {% set eff_constitution  = fiche.constitution  + (bonusNomFamille == 'constitution'  ? 1 : 0) + (bonusNomEcole == 'constitution'  ? 1 : 0) %}
            {% set eff_volonte       = fiche.volonte       + (bonusNomFamille == 'volonte'        ? 1 : 0) + (bonusNomEcole == 'volonte'        ? 1 : 0) %}
            {% set eff_reflexes      = fiche.reflexes      + (bonusNomFamille == 'reflexes'       ? 1 : 0) + (bonusNomEcole == 'reflexes'       ? 1 : 0) %}
            {% set eff_intuition     = fiche.intuition     + (bonusNomFamille == 'intuition'      ? 1 : 0) + (bonusNomEcole == 'intuition'      ? 1 : 0) %}
            {% set eff_agilite       = fiche.agilite       + (bonusNomFamille == 'agilite'        ? 1 : 0) + (bonusNomEcole == 'agilite'        ? 1 : 0) %}
            {% set eff_intelligence  = fiche.intelligence  + (bonusNomFamille == 'intelligence'   ? 1 : 0) + (bonusNomEcole == 'intelligence'   ? 1 : 0) %}
            {% set eff_forceStat     = fiche.forceStat     + (bonusNomFamille == 'forceStat'      ? 1 : 0) + (bonusNomEcole == 'forceStat'      ? 1 : 0) %}
            {% set eff_perception    = fiche.perception    + (bonusNomFamille == 'perception'     ? 1 : 0) + (bonusNomEcole == 'perception'     ? 1 : 0) %}
            {% set eff_vide          = fiche.vide          + (bonusNomFamille == 'vide'           ? 1 : 0) + (bonusNomEcole == 'vide'           ? 1 : 0) %}

            {% set b_constitution = (bonusNomFamille == 'constitution' or bonusNomEcole == 'constitution') %}
            {% set b_volonte      = (bonusNomFamille == 'volonte'      or bonusNomEcole == 'volonte')      %}
            {% set b_reflexes     = (bonusNomFamille == 'reflexes'     or bonusNomEcole == 'reflexes')     %}
            {% set b_intuition    = (bonusNomFamille == 'intuition'    or bonusNomEcole == 'intuition')    %}
            {% set b_agilite      = (bonusNomFamille == 'agilite'      or bonusNomEcole == 'agilite')      %}
            {% set b_intelligence = (bonusNomFamille == 'intelligence' or bonusNomEcole == 'intelligence') %}
            {% set b_forceStat    = (bonusNomFamille == 'forceStat'    or bonusNomEcole == 'forceStat')    %}
            {% set b_perception   = (bonusNomFamille == 'perception'   or bonusNomEcole == 'perception')   %}
            {% set b_vide         = (bonusNomFamille == 'vide'         or bonusNomEcole == 'vide')         %}

            {% set cout_constitution = eff_constitution > (b_constitution ? 3 : 2) ? (4 * (eff_constitution * (eff_constitution + 1) / 2 - (b_constitution ? 6 : 3)))|round : 0 %}
            {% set cout_volonte      = eff_volonte      > (b_volonte      ? 3 : 2) ? (4 * (eff_volonte      * (eff_volonte      + 1) / 2 - (b_volonte      ? 6 : 3)))|round : 0 %}
            {% set cout_reflexes     = eff_reflexes     > (b_reflexes     ? 3 : 2) ? (4 * (eff_reflexes     * (eff_reflexes     + 1) / 2 - (b_reflexes     ? 6 : 3)))|round : 0 %}
            {% set cout_intuition    = eff_intuition    > (b_intuition    ? 3 : 2) ? (4 * (eff_intuition    * (eff_intuition    + 1) / 2 - (b_intuition    ? 6 : 3)))|round : 0 %}
            {% set cout_agilite      = eff_agilite      > (b_agilite      ? 3 : 2) ? (4 * (eff_agilite      * (eff_agilite      + 1) / 2 - (b_agilite      ? 6 : 3)))|round : 0 %}
            {% set cout_intelligence = eff_intelligence > (b_intelligence ? 3 : 2) ? (4 * (eff_intelligence * (eff_intelligence + 1) / 2 - (b_intelligence ? 6 : 3)))|round : 0 %}
            {% set cout_forceStat    = eff_forceStat    > (b_forceStat    ? 3 : 2) ? (4 * (eff_forceStat    * (eff_forceStat    + 1) / 2 - (b_forceStat    ? 6 : 3)))|round : 0 %}
            {% set cout_perception   = eff_perception   > (b_perception   ? 3 : 2) ? (4 * (eff_perception   * (eff_perception   + 1) / 2 - (b_perception   ? 6 : 3)))|round : 0 %}
            {% set cout_vide         = eff_vide         > (b_vide         ? 3 : 2) ? (6 * (eff_vide         * (eff_vide         + 1) / 2 - (b_vide         ? 6 : 3)))|round : 0 %}

            {% set cout_traits_total = cout_constitution + cout_volonte + cout_reflexes + cout_intuition + cout_forceStat + cout_perception + cout_agilite + cout_intelligence + cout_vide %}
            {% set cout_competences_total = 0 %}
            {% for i in 1..20 %}
                {% set val = attribute(fiche, 'valeur' ~ i) %}
                {% if attribute(fiche, 'competence' ~ i) is not empty and val %}
                    {% set cout_competences_total = cout_competences_total + (val * (val + 1) / 2)|round %}
                {% endif %}
            {% endfor %}
            {% set depart_ecole = (fiche.personnage.ecole is not empty and fiche.personnage.ecole.valeurCompetencesDepart) ? fiche.personnage.ecole.valeurCompetencesDepart : 0 %}
            {% set cout_competences_total = cout_competences_total - depart_ecole > 0 ? cout_competences_total - depart_ecole : 0 %}

            <article class="card mt-3 p-3">
            <div class="row card-body">
                <div class="col-8 card-text">
                    <div class="row">

                        <div class="col-6 card-text">
                            <ul>
                                <li>Clan : <strong><a href="{{ path('empire_clan', {id: fiche.personnage.clan.id}) }}">{{ fiche.personnage.clan.nom }}</a></strong></li>
                                <li>Classe : <strong><a href="{{ path('regles_classe', {id: fiche.personnage.classe.id}) }}">{{ fiche.personnage.classe.nom }}</a></strong></li>
                                <li>Ecole : <strong><a href="{{ path('regles_ecole', {id: fiche.personnage.ecole.id}) }}">{{ fiche.personnage.ecole.nom }}</a></strong></li>
                                <li>Rang : <strong>{{ rang }}</strong></li>

                            </ul>
                        </div>
                        <div class="col-6 card-text">
                            <ul>
                                <li>XP Création : <strong>{{ xp_creation }} XP</strong></li>
                                <li>XP Progression : <strong>{{ xp_progression }} XP</strong></li>
                                <li>XP Total : <strong>{{ xp_total }} XP</strong></li>
                                <li>XP Dépensés : <strong class="text-danger">-{{ cout_traits_total + cout_competences_total }} xp</strong></li>
                                <li>XP Restant : <strong class="text-success">{{ xp_total - (cout_traits_total + cout_competences_total) }} xp</strong></li>
                            </ul>
                        </div>

                        <div class="col-12 card-text">
                            <hr>
                            <p class="text-center">
                                <span class="text-danger h5">XP dépensés en traits : -{{ cout_constitution + cout_volonte + cout_reflexes + cout_intuition + cout_forceStat + cout_perception + cout_agilite + cout_intelligence + cout_vide }} xp</span>
                            </p>
                            <div class="row text-center">
                                <div class="col-4 offset-2">
                                    <span class="display-4">{{ min(eff_constitution, eff_volonte) }}</span>
                                    <br/>Anneau de Terre
                                    <br/><strong>{% if cout_constitution > 0 %}<small class="text-danger">-{{ cout_constitution }} xp</small> {% endif %}Constitution : {{ eff_constitution }}{% if bonusNomFamille == 'constitution' or bonusNomEcole == 'constitution' %} <small class="text-success">(bonus)</small>{% endif %}</strong>
                                    <br/><strong>{% if cout_volonte > 0 %}<small class="text-danger">-{{ cout_volonte }} xp</small> {% endif %}Volonté : {{ eff_volonte }}{% if bonusNomFamille == 'volonte' or bonusNomEcole == 'volonte' %} <small class="text-success">(bonus)</small>{% endif %}</strong>
                                </div>
                                <div class="col-4">
                                    <span class="display-4">{{ min(eff_reflexes, eff_intuition) }}</span>
                                    <br/>Anneau de l'Air
                                    <br/><strong>{% if cout_reflexes > 0 %}<small class="text-danger">-{{ cout_reflexes }} xp</small> {% endif %}Réflexes : {{ eff_reflexes }}{% if bonusNomFamille == 'reflexes' or bonusNomEcole == 'reflexes' %} <small class="text-success">(bonus)</small>{% endif %}</strong>
                                    <br/><strong>{% if cout_intuition > 0 %}<small class="text-danger">-{{ cout_intuition }} xp</small> {% endif %}Intuition : {{ eff_intuition }}{% if bonusNomFamille == 'intuition' or bonusNomEcole == 'intuition' %} <small class="text-success">(bonus)</small>{% endif %}</strong>
                                </div>
                            </div>

                            <div class="row text-center">

                                <div class="col-4 offset-1">
                                    <span class="display-4">{{ min(eff_forceStat, eff_perception) }}</span>
                                    <br/>Anneau de l'Eau
                                    <br/><strong>{% if cout_forceStat > 0 %}<small class="text-danger">-{{ cout_forceStat }} xp</small> {% endif %}Force : {{ eff_forceStat }}{% if bonusNomFamille == 'forceStat' or bonusNomEcole == 'forceStat' %} <small class="text-success">(bonus)</small>{% endif %}</strong>
                                    <br/><strong>{% if cout_perception > 0 %}<small class="text-danger">-{{ cout_perception }} xp</small> {% endif %}Perception : {{ eff_perception }}{% if bonusNomFamille == 'perception' or bonusNomEcole == 'perception' %} <small class="text-success">(bonus)</small>{% endif %}</strong>
                                </div>

                                <div class="col-2">
                                    <img class="img-fluid" src="{{ asset('assets/img/icons/5rings.png') }}" alt="La 5 anneaux" />
                                </div>

                                <div class="col-4">
                                    <span class="display-4">{{ min(eff_agilite, eff_intelligence) }}</span>
                                    <br/>Anneau du Feu :
                                    <br/><strong>{% if cout_agilite > 0 %}<small class="text-danger">-{{ cout_agilite }} xp</small> {% endif %}Agilité : {{ eff_agilite }}{% if bonusNomFamille == 'agilite' or bonusNomEcole == 'agilite' %} <small class="text-success">(bonus)</small>{% endif %}</strong>
                                    <br/><strong>{% if cout_intelligence > 0 %}<small class="text-danger">-{{ cout_intelligence }} xp</small> {% endif %}Intelligence : {{ eff_intelligence }}{% if bonusNomFamille == 'intelligence' or bonusNomEcole == 'intelligence' %} <small class="text-success">(bonus)</small>{% endif %}</strong>
                                </div>

                            </div>

                            <div class="row text-center">
                                <div class="offset-4 col-4">
                                    <span class="display-4">{{ eff_vide }}{% if bonusNomFamille == 'vide' or bonusNomEcole == 'vide' %} <small class="text-success">(bonus)</small>{% endif %}</span>
                                    <br/>{% if cout_vide > 0 %}<small class="text-danger">-{{ cout_vide }} xp</small> {% endif %}Anneau du Vide
                                </div>
                            </div>              
                        </div>

                    </div>
                </div>
                <div class="col-4">
                    <img class="img-fluid" src="{{ asset(fiche.personnage.illustration|default(NA_PERSO_ILLU)) }}" />
                </div>
                <div class="col-8">
                    <hr>
                    <div class="row">
                        <div class="col-12 mb-2">
                            {% if est_le_joueur or is_granted('ROLE_MJ') %}
                                <a class="btn btn-sm btn-outline-secondary" data-toggle="collapse" href="#avantagesSection" role="button" aria-expanded="false">
                                    <i class="fas fa-eye-slash mr-1"></i> Avantages / Désavantages <small class="text-muted">(visible par le joueur et le MJ uniquement)</small>
                                </a>
                                <div class="collapse mt-2" id="avantagesSection">
                                    <div class="row">
                                        <div class="col-6">
                                            Avantages :<br/>
                                            {% if fiche.avantage1 %}
                                                <strong>{{ fiche.avantage1.nom }}</strong>
                                                <i class="fas fa-info-circle text-info" data-toggle="tooltip" data-placement="right" title="{{ fiche.avantage1.description }}"></i>
                                            {% else %}<strong>—</strong>{% endif %}<br/>
                                            {% if fiche.avantage2 %}
                                                <strong>{{ fiche.avantage2.nom }}</strong>
                                                <i class="fas fa-info-circle text-info" data-toggle="tooltip" data-placement="right" title="{{ fiche.avantage2.description }}"></i>
                                            {% else %}<strong>—</strong>{% endif %}
                                        </div>
                                        <div class="col-6">
                                            Désavantages :<br/>
                                            {% if fiche.desavantage1 %}
                                                <strong>{{ fiche.desavantage1.nom }}</strong>
                                                <i class="fas fa-info-circle text-warning" data-toggle="tooltip" data-placement="right" title="{{ fiche.desavantage1.description }}"></i>
                                            {% else %}<strong>—</strong>{% endif %}<br/>
                                            {% if fiche.desavantage2 %}
                                                <strong>{{ fiche.desavantage2.nom }}</strong>
                                                <i class="fas fa-info-circle text-warning" data-toggle="tooltip" data-placement="right" title="{{ fiche.desavantage2.description }}"></i>
                                            {% else %}<strong>—</strong>{% endif %}
                                        </div>
                                        <div class="col-4 mt-2">
                                            Souillure : <strong>{{ fiche.souillure ?? '—' }}</strong>
                                        </div>
                                    </div>
                                </div>
                            {% else %}
                                <span class="text-muted">
                                    <i class="fas fa-lock mr-1"></i> Avantages / Désavantages <small>(non visible car vous n'êtes pas le joueur ou le MJ)</small>
                                </span>
                            {% endif %}
                        </div>
                        <div class="col-4">
                            Honneur : <strong>{{ fiche.honneur ?? '—' }}</strong>
                        </div>
                        <div class="col-4">
                            Gloire : <strong>{{ fiche.gloire ?? '—' }}</strong>
                        </div>
                        <div class="col-4">
                            Infamie : <strong>{{ fiche.infamie ?? '—' }}</strong>
                        </div>
                    </div>
                    <p class="text-center">
                        <span class="text-danger h5">XP dépensés en compétences : -{{ cout_competences_total }} xp</span>
                        {% if depart_ecole > 0 %}
                            <br/><span class="text-success">(en comptant {{ depart_ecole }} xp déduit des compétences offertes de l'école)</span>
                        {% endif %}
                    </p>

                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th scope="col">Compétence</th>
                                <th scope="col">Rang</th>
                                <th scope="col">Trait</th>
                                <th scope="col" class="text-danger">Coût XP</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for i in 1..20 %}
                                {% set comp = attribute(fiche, 'competence' ~ i) %}
                                {% set val  = attribute(fiche, 'valeur' ~ i) %}
                                {% if comp is not empty %}
                                    <tr>
                                        <th scope="row">{{ comp.nom }}</th>
                                        <td>{{ val }}</td>
                                        <td>{{ comp.trait }}</td>
                                        <td class="text-danger">-{{ (val * (val + 1) / 2)|round }} xp</td>
                                    </tr>
                                {% endif %}
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
                <div class="col-4">
                    <div class="card mt-3">
                        <div class="card-body">
                            <h4 class="card-title">Statistique de Combat</h4>
                        </div>
                        <ul class="list-group list-group-flush">
                            {% set arme_lourde = fiche.arme and fiche.arme.type == 'LOURDE' %}
                            <li class="list-group-item">Initiative : <strong>{{ rang + eff_reflexes }}g{{ eff_reflexes }}</strong>{% if arme_lourde %}<br/><small class="text-danger">-5 initiative (arme lourde)</small>{% endif %}</li>
                            <li class="list-group-item">Arme ({{ fiche.arme ? fiche.arme.nom : '—' }}) : <strong>{{ fiche.arme ? fiche.arme.vd : '—' }}</strong></li>
                            <li class="list-group-item">Armure ({{ fiche.armure ? fiche.armure.nom : '—' }}) : <br/><strong>{% if fiche.armure %}+{{ fiche.armure.ndArmure }} ND <br/>  +{{ fiche.armure.reduction }} Réduction{% else %}—{% endif %}</strong></li>
                            <li class="list-group-item">ND d'Armure : <strong>{{ 5 + eff_reflexes * 5 }}{% if fiche.armure and fiche.armure.ndArmure %} +{{ fiche.armure.ndArmure }} = {{ 5 + eff_reflexes * 5 + fiche.armure.ndArmure }}{% endif %}</strong></li>
                            {% set reduction_armure = fiche.armure ? fiche.armure.reduction : 0 %}
                            {% set reduction_special = fiche.reductionSpecial ?? 0 %}
                            <li class="list-group-item">Réduction d'Armure : <strong>{{ reduction_armure + reduction_special }}</strong>{% if reduction_special > 0 %} <small class="text-muted">({{ reduction_armure }} armure +{{ reduction_special }} spécial)</small>{% endif %}</li>
                        </ul>
                        <table class="table table-striped text-center">
                            <thead>
                                <tr>
                                    <th>Etat</th>
                                    <th>Malus</th>
                                    <th>HP</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>Indemne</td>
                                    <td>0</td>
                                    <td>{{ 5*min(eff_constitution, eff_volonte) }}</td>
                                </tr>
                                <tr>
                                    <td>Egratiné</td>
                                    <td>+3</td>
                                    <td>{{ 2*min(eff_constitution, eff_volonte) }}</td>
                                </tr>
                                <tr>
                                    <td>Légerement blessé</td>
                                    <td>+5</td>
                                    <td>{{ 2*min(eff_constitution, eff_volonte) }}</td>
                                </tr>
                                <tr>
                                    <td>Blessé</td>
                                    <td>+10</td>
                                    <td>{{ 2*min(eff_constitution, eff_volonte) }}</td>
                                </tr>
                                <tr>
                                    <td>Gravement blessé</td>
                                    <td>+15</td>
                                    <td>{{ 2*min(eff_constitution, eff_volonte) }}</td>
                                </tr>
                                <tr>
                                    <td>Impotent</td>
                                    <td>+20</td>
                                    <td>{{ 2*min(eff_constitution, eff_volonte) }}</td>
                                </tr>
                                <tr>
                                    <td>Epuisé</td>
                                    <td>+30</td>
                                    <td>{{ 2*min(eff_constitution, eff_volonte) }}</td>
                                </tr>
                                <tr>
                                    <td>Hors de Combat</td>
                                    <td>ne peut agir</td>
                                    <td>{{ 2*min(eff_constitution, eff_volonte) }}</td>
                                </tr>
                            </tbody>
                        </table>
                        {% set terre = min(eff_constitution, eff_volonte) %}
                        <div class="card-footer text-center">
                            HP Total : <strong>{{ 5*terre + 7*(2*terre) }}</strong>
                        </div>
                    </div>
{# <div class="card mt-3">
                        <div class="card-body">
                            <h4 class="card-title">Inventaire</h4>
                        </div>
                        <ul class="list-group list-group-flush">
                            <li class="list-group-item">Item 1</li>
                            <li class="list-group-item">Item 2</li>
                            <li class="list-group-item">Item 3</li>
                        </ul>
                    </div> #}
                </div>
            </div>
        </article>

        </section>
    </main>

{{ include('/parts/modal.html.twig') }}

{% block javascripts %}
    {{ parent() }}
    <script>
        $(function () { $('[data-toggle="tooltip"]').tooltip(); });
    </script>
{% endblock %}

{% endblock %}
