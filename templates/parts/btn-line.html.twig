{% set path = 'admin_' ~ entity ~ '_' ~ action %}
{% if action == 'delete' %}
<form method="POST" action="{{ path(path, {id: un_element.id}) }}{% if redirect is defined and redirect is not empty %}?redirect={{redirect}}{% endif %}" style="display:inline" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet élément ?')">
    <input type="hidden" name="_csrf_token" value="{{ csrf_token('delete' ~ un_element.id) }}">
    <button type="submit" class="btn-quaternary-style {{color}}">
        <i class="fas fa-trash-alt" alt="Icône Supprimer"></i>
        &nbsp;&nbsp;Supprimer
    </button>
</form>
{% else %}
<a class="btn-quaternary-style {{color}}"
    href="{{ path(path, {id: un_element.id} ) }}{% if redirect is defined and redirect is not empty %}?redirect={{redirect}}{% endif %}">
        <i class="fas fa-edit" alt="Icône Modifier"></i>
        &nbsp;&nbsp;Modifier
</a>
{% endif %}